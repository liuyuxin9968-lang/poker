<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>🌐 在线21点 · Netlify版</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
        }
        body {
            background: #1a1a1a;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            color: #eee;
            min-height: 100vh;
            padding: 10px;
        }
        #app {
            max-width: 600px;
            margin: 0 auto;
            width: 100%;
        }

        /* 顶部栏 */
        .top-bar {
            background: #2a2a2a;
            border: 2px solid #ffd700;
            border-radius: 40px;
            padding: 10px 15px;
            margin-bottom: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
        }
        .title-section {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }
        .game-title {
            font-size: 1.2rem;
            font-weight: bold;
            color: gold;
        }
        .network-status {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 0.8rem;
            background: #1a1a1a;
            padding: 4px 10px;
            border-radius: 30px;
            border: 1px solid #444;
        }
        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #ff4444;
            box-shadow: 0 0 8px #ff4444;
        }
        .status-dot.connected {
            background: #00ff00;
            box-shadow: 0 0 8px #00ff00;
        }
        .player-info {
            display: flex;
            align-items: center;
            gap: 10px;
            background: #1a1a1a;
            padding: 5px 12px;
            border-radius: 30px;
            border: 1px solid gold;
        }
        .gold-display {
            font-size: 1rem;
            font-weight: bold;
            color: gold;
        }

        /* 按钮 */
        button {
            background: #2a2a2a;
            color: #ffd700;
            border: 2px solid #ffd700;
            border-radius: 40px;
            padding: 12px 20px;
            font-weight: bold;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.1s;
            min-width: 60px;
            touch-action: manipulation;
        }
        button:active {
            background: #ffd700;
            color: #1a1a1a;
            transform: scale(0.98);
        }
        button.primary {
            background: #ffd700;
            color: #1a1a1a;
        }
        button.small {
            padding: 8px 12px;
            font-size: 0.9rem;
        }
        button.danger {
            border-color: #ff4444;
            color: #ff4444;
        }

        /* 房间列表 */
        .room-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin: 15px 0;
            max-height: 60vh;
            overflow-y: auto;
        }
        .room-item {
            background: #2a5a2a;
            border: 2px solid gold;
            border-radius: 20px;
            padding: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
        }
        .room-item:active {
            background: #3a6a3a;
        }

        /* 玩家网格 */
        .players-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
            gap: 8px;
            margin: 15px 0;
        }
        .player-card {
            background: #1e3a1e;
            border: 2px solid #b8860b;
            border-radius: 16px;
            padding: 10px;
            text-align: center;
        }
        .player-card.me {
            border-color: gold;
            background: #2a4a2a;
        }
        .player-card .host-badge {
            color: gold;
            font-size: 1.2rem;
        }

        /* 座位滑动区 */
        .seats-scroll {
            display: flex;
            overflow-x: auto;
            gap: 12px;
            padding: 10px 0 20px;
            scroll-snap-type: x mandatory;
            -webkit-overflow-scrolling: touch;
        }
        .seat {
            flex: 0 0 160px;
            scroll-snap-align: start;
            background: #1e3a1e;
            border: 2px solid #b8860b;
            border-radius: 24px;
            padding: 15px 10px;
            text-align: center;
            min-height: 200px;
            display: flex;
            flex-direction: column;
        }
        .seat.occupied {
            border-color: gold;
            background: #2a4a2a;
        }
        .seat.highlight {
            border: 3px solid #ffd700;
            box-shadow: 0 0 15px gold;
        }
        .seat .hand-cards {
            font-size: 1.8rem;
            letter-spacing: 4px;
            margin: 8px 0;
            word-break: break-word;
        }
        .points-badge {
            background: gold;
            color: black;
            border-radius: 20px;
            padding: 4px 8px;
            font-size: 0.9rem;
            font-weight: bold;
            display: inline-block;
            margin: 5px auto;
        }

        /* 筹码滑动区 */
        .chips-scroll {
            display: flex;
            overflow-x: auto;
            gap: 8px;
            padding: 10px 0;
            -webkit-overflow-scrolling: touch;
        }
        .chip {
            flex: 0 0 60px;
            height: 60px;
            line-height: 56px;
            text-align: center;
            background: #333;
            border: 2px solid gold;
            border-radius: 50%;
            font-weight: bold;
            font-size: 1.1rem;
        }
        .chip:active {
            background: gold;
            color: black;
        }

        /* 底部操作栏 */
        .action-bar {
            position: sticky;
            bottom: 10px;
            background: #2a2a2a;
            border: 2px solid gold;
            border-radius: 50px;
            padding: 10px;
            display: flex;
            gap: 8px;
            justify-content: center;
            flex-wrap: wrap;
            margin-top: 15px;
            backdrop-filter: blur(10px);
        }
        .action-bar button {
            flex: 1;
            min-width: 70px;
            padding: 12px 5px;
            font-size: 0.9rem;
        }

        /* 弹窗 */
        .modal {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 90%;
            max-width: 350px;
            background: #2a2a2a;
            border: 3px solid gold;
            border-radius: 30px;
            padding: 25px;
            z-index: 1000;
        }
        .overlay {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.8);
            z-index: 999;
        }
        .hidden {
            display: none !important;
        }

        input, select {
            width: 100%;
            padding: 15px;
            margin: 10px 0;
            border-radius: 30px;
            border: none;
            background: #3a3a3a;
            color: white;
            font-size: 1rem;
            -webkit-appearance: none;
        }

        .room-header {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 15px;
        }
        .room-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .dealer-area {
            background: #1e3a1e;
            border-radius: 30px;
            padding: 15px;
            margin: 15px 0;
            text-align: center;
            border: 2px solid #b8860b;
        }

        .connection-settings {
            background: #2a2a2a;
            border-radius: 20px;
            padding: 15px;
            margin: 15px 0;
            border: 1px solid gold;
        }

        /* Netlify 部署说明 */
        .deploy-info {
            background: #1e3a1e;
            border-radius: 20px;
            padding: 10px;
            margin: 10px 0;
            font-size: 0.8rem;
            text-align: center;
            border: 1px solid #b8860b;
        }
    </style>
</head>
<body>
<div id="app">
    <!-- 顶部栏 -->
    <div class="top-bar">
        <div class="title-section">
            <span class="game-title">🎰 在线21点</span>
            <span class="network-status" id="networkStatus">
                <span class="status-dot" id="statusDot"></span>
                <span id="statusText">未连接</span>
            </span>
        </div>
        <div class="player-info">
            <span id="nicknameDisplay" style="font-size:0.9rem;">玩家</span>
            <span class="gold-display" id="goldAmount">💰10000</span>
        </div>
    </div>

    <!-- Netlify部署提示 -->
    <div class="deploy-info" id="deployInfo">
        🌐 已部署到 Netlify | WebSocket服务器: <span id="wsServerDisplay">等待连接</span>
    </div>

    <!-- 连接设置 -->
    <div id="connectionView">
        <div class="connection-settings">
            <h3 style="margin-bottom:10px;">🔌 连接游戏服务器</h3>
            <p style="font-size:0.9rem; color:#ffd700; margin-bottom:10px;">👉 您需要先部署Cloudflare Workers WebSocket服务器，然后把地址填在下面</p>
            <input type="text" id="wsServerInput" placeholder="wss://your-worker.workers.dev" value="">
            <button onclick="connectToServer()" style="width:100%;" class="primary">🔗 连接服务器</button>
            <p style="font-size:0.8rem; color:#aaa; margin-top:10px;">部署教程在页面最底部</p>
        </div>
    </div>

    <!-- 大厅界面 -->
    <div id="lobbyView" class="hidden">
        <div style="display:flex; gap:8px; margin-bottom:15px;">
            <button class="primary" style="flex:2;" onclick="showCreateRoomModal()">➕ 创建房间</button>
            <button style="flex:1;" onclick="refreshRooms()">🔄 刷新</button>
        </div>
        
        <h3 style="margin-bottom:10px;">📋 游戏房间</h3>
        <div id="roomList" class="room-list">
            <div class="room-item">
                <div>⏳ 等待服务器连接...</div>
            </div>
        </div>
    </div>

    <!-- 房间内界面 -->
    <div id="roomView" class="hidden">
        <div class="room-header">
            <div style="display:flex; justify-content:space-between; align-items:center;">
                <h2 id="roomNameDisplay" style="font-size:1.2rem;">房间名称</h2>
                <span style="font-size:0.8rem; color:#aaa;" id="roomIdDisplay"></span>
            </div>
            <div class="room-actions">
                <button class="small" onclick="copyRoomInvite()">📋 复制邀请</button>
                <button class="small danger" onclick="leaveRoom()">🚪 离开</button>
            </div>
        </div>

        <!-- 玩家列表 -->
        <h3>👥 在线玩家</h3>
        <div id="playerList" class="players-grid"></div>

        <!-- 游戏控制（房主） -->
        <div id="gameControls" class="hidden" style="text-align:center; margin:10px 0;">
            <button class="primary" onclick="startGame()" style="width:100%;">🎲 开始游戏</button>
        </div>

        <!-- 庄家区域 -->
        <div id="dealerArea" class="dealer-area hidden">
            <div style="font-size:0.9rem;">👑 庄家</div>
            <div id="dealerHand" class="hand-cards"></div>
            <div id="dealerPoints" class="points-badge"></div>
        </div>

        <!-- 座位区域 -->
        <h3>🪑 座位</h3>
        <div id="seatsContainer" class="seats-scroll"></div>

        <!-- 下注筹码 -->
        <div id="bettingArea" class="hidden">
            <h4 style="margin:5px 0;">下注</h4>
            <div class="chips-scroll">
                <span class="chip" onclick="placeBet(25)">25</span>
                <span class="chip" onclick="placeBet(50)">50</span>
                <span class="chip" onclick="placeBet(100)">100</span>
                <span class="chip" onclick="placeBet(200)">200</span>
                <span class="chip" onclick="placeBet(500)">500</span>
                <span class="chip" onclick="placeBet(1000)">1k</span>
                <span class="chip" onclick="placeBet(2000)">2k</span>
            </div>
        </div>

        <!-- 操作按钮 -->
        <div id="actionArea" class="action-bar hidden">
            <button onclick="playerAction('hit')">要牌</button>
            <button onclick="playerAction('stand')">停牌</button>
            <button onclick="playerAction('double')">加倍</button>
            <button onclick="playerAction('split')">分牌</button>
        </div>
    </div>

    <!-- 创建房间弹窗 -->
    <div id="createRoomOverlay" class="overlay hidden" onclick="closeCreateRoomModal()"></div>
    <div id="createRoomModal" class="modal hidden">
        <h3 style="margin-bottom:15px;">创建房间</h3>
        <input type="text" id="roomNameInput" placeholder="房间名称" value="21点房间">
        <input type="number" id="maxPlayersInput" placeholder="最多几人" value="8" min="2" max="10">
        <div style="display:flex; gap:8px; margin-top:15px;">
            <button style="flex:1;" onclick="closeCreateRoomModal()">取消</button>
            <button class="primary" style="flex:1;" onclick="createRoom()">创建</button>
        </div>
    </div>

    <!-- 加入房间弹窗 -->
    <div id="joinRoomOverlay" class="overlay hidden" onclick="closeJoinModal()"></div>
    <div id="joinRoomModal" class="modal hidden">
        <h3 id="joinRoomTitle" style="margin-bottom:10px;">加入房间</h3>
        <div style="margin:10px 0; font-size:0.9rem;">
            <div>房主: <span id="joinHostName"></span></div>
            <div>人数: <span id="joinPlayerCount"></span>/<span id="joinMaxPlayers"></span></div>
        </div>
        <input type="number" id="joinGoldInput" placeholder="携带金币" value="10000" min="1000" max="1000000">
        <div style="display:flex; gap:8px; margin-top:15px;">
            <button style="flex:1;" onclick="closeJoinModal()">取消</button>
            <button class="primary" style="flex:1;" onclick="joinRoom()">加入</button>
        </div>
    </div>
</div>

<script>
    // ========== WebSocket 连接管理 ==========
    class WebSocketClient {
        constructor() {
            this.ws = null;
            this.roomId = null;
            this.playerId = localStorage.getItem('player_id');
            if (!this.playerId) {
                this.playerId = 'player_' + Date.now() + '_' + Math.random().toString(36).substring(2, 8);
                localStorage.setItem('player_id', this.playerId);
            }
            this.isHost = false;
            this.onMessageCallbacks = [];
            this.onConnectCallbacks = [];
            this.onDisconnectCallbacks = [];
            this.connected = false;
            this.reconnectAttempts = 0;
            this.serverUrl = null;
        }

        connect(serverUrl) {
            this.serverUrl = serverUrl;
            return new Promise((resolve, reject) => {
                try {
                    this.ws = new WebSocket(serverUrl);
                    
                    this.ws.onopen = () => {
                        console.log('WebSocket 连接成功');
                        this.connected = true;
                        this.reconnectAttempts = 0;
                        this.updateStatus('connected');
                        
                        // 发送初始化消息
                        this.send({
                            type: 'init',
                            playerId: this.playerId,
                            nickname: localStorage.getItem('player_nickname')
                        });
                        
                        this.onConnectCallbacks.forEach(cb => cb());
                        resolve();
                    };

                    this.ws.onmessage = (event) => {
                        try {
                            const data = JSON.parse(event.data);
                            console.log('收到:', data);
                            this.onMessageCallbacks.forEach(cb => cb(data));
                        } catch (e) {
                            console.error('解析消息失败:', e);
                        }
                    };

                    this.ws.onclose = () => {
                        console.log('WebSocket 连接断开');
                        this.connected = false;
                        this.updateStatus('disconnected');
                        this.onDisconnectCallbacks.forEach(cb => cb());
                        
                        // 尝试重连
                        if (this.reconnectAttempts < 3) {
                            this.reconnectAttempts++;
                            setTimeout(() => this.connect(serverUrl), 3000);
                        }
                    };

                    this.ws.onerror = (error) => {
                        console.error('WebSocket 错误:', error);
                        reject(error);
                    };
                } catch (e) {
                    reject(e);
                }
            });
        }

        send(message) {
            if (this.ws && this.ws.readyState === WebSocket.OPEN) {
                message.playerId = this.playerId;
                message.timestamp = Date.now();
                this.ws.send(JSON.stringify(message));
            } else {
                console.warn('WebSocket 未连接');
            }
        }

        updateStatus(status) {
            const dot = document.getElementById('statusDot');
            const text = document.getElementById('statusText');
            const wsDisplay = document.getElementById('wsServerDisplay');
            
            if (status === 'connected') {
                dot.className = 'status-dot connected';
                text.innerText = '已连接';
                if (wsDisplay) wsDisplay.innerText = this.serverUrl || '已连接';
            } else {
                dot.className = 'status-dot';
                text.innerText = '未连接';
                if (wsDisplay) wsDisplay.innerText = '未连接';
            }
        }

        onMessage(callback) {
            this.onMessageCallbacks.push(callback);
        }

        onConnect(callback) {
            this.onConnectCallbacks.push(callback);
        }

        onDisconnect(callback) {
            this.onDisconnectCallbacks.push(callback);
        }

        disconnect() {
            if (this.ws) {
                this.ws.close();
            }
        }
    }

    // ========== 游戏核心 ==========
    class GameManager {
        constructor() {
            this.ws = new WebSocketClient();
            this.players = new Map();
            this.seats = Array(10).fill(null);
            this.gameState = 'waiting';
            this.currentPlayer = null;
            this.deck = [];
            this.dealerHand = [];
            this.dealerHidden = true;
            this.roomInfo = null;
            this.dealer = null;
            
            // 绑定消息处理
            this.ws.onMessage((msg) => {
                this.handleMessage(msg);
            });

            this.ws.onConnect(() => {
                document.getElementById('connectionView').classList.add('hidden');
                document.getElementById('lobbyView').classList.remove('hidden');
                this.refreshRooms();
            });

            this.ws.onDisconnect(() => {
                document.getElementById('connectionView').classList.remove('hidden');
                document.getElementById('lobbyView').classList.add('hidden');
                document.getElementById('roomView').classList.add('hidden');
            });
        }

        initPlayer() {
            let nickname = localStorage.getItem('player_nickname');
            if (!nickname) {
                nickname = prompt('请输入昵称', '玩家' + Math.floor(Math.random() * 1000));
                localStorage.setItem('player_nickname', nickname);
            }
            
            let gold = localStorage.getItem('player_gold');
            if (!gold) {
                gold = 10000;
                localStorage.setItem('player_gold', gold);
            }
            
            return { nickname, gold: parseInt(gold) };
        }

        updateGoldDisplay() {
            let gold = localStorage.getItem('player_gold') || 10000;
            document.getElementById('goldAmount').innerHTML = `💰${gold}`;
            document.getElementById('nicknameDisplay').innerText = localStorage.getItem('player_nickname');
        }

        connectToServer(serverUrl) {
            // 保存到 localStorage，下次自动加载
            localStorage.setItem('ws_server', serverUrl);
            return this.ws.connect(serverUrl);
        }

        createRoom(name, maxPlayers) {
            this.ws.send({
                type: 'createRoom',
                roomName: name,
                maxPlayers: maxPlayers
            });
        }

        refreshRooms() {
            this.ws.send({
                type: 'getRooms'
            });
        }

        joinRoom(roomId, gold) {
            localStorage.setItem('player_gold', gold);
            this.ws.send({
                type: 'joinRoom',
                roomId: roomId,
                gold: gold
            });
        }

        leaveRoom() {
            this.ws.send({
                type: 'leaveRoom'
            });
            this.roomInfo = null;
            this.seats = Array(10).fill(null);
            this.renderLobby();
        }

        sitDown(seatIndex) {
            let gold = parseInt(localStorage.getItem('player_gold'));
            let buyIn = prompt('购买积分（最低2000），可用: ' + gold, '2000');
            if (!buyIn) return;
            let buyInt = parseInt(buyIn);
            if (isNaN(buyInt) || buyInt < 2000 || buyInt > gold) {
                alert('金额无效');
                return;
            }
            
            localStorage.setItem('player_gold', gold - buyInt);
            
            this.ws.send({
                type: 'sitDown',
                seat: seatIndex,
                points: buyInt
            });
        }

        placeBet(amount) {
            this.ws.send({
                type: 'placeBet',
                amount: amount
            });
        }

        startGame() {
            this.ws.send({
                type: 'startGame'
            });
        }

        playerAction(action) {
            this.ws.send({
                type: 'playerAction',
                action: action
            });
        }

        handleMessage(msg) {
            console.log('处理消息:', msg);
            
            switch(msg.type) {
                case 'roomList':
                    this.renderRoomList(msg.rooms);
                    break;
                    
                case 'roomJoined':
                    this.roomInfo = msg.room;
                    this.players = new Map(msg.players.map(p => [p.playerId, p]));
                    this.seats = msg.seats || Array(10).fill(null);
                    this.renderRoom();
                    break;
                    
                case 'playerJoined':
                    this.players.set(msg.player.playerId, msg.player);
                    this.renderRoom();
                    break;
                    
                case 'playerLeft':
                    this.players.delete(msg.playerId);
                    // 清理座位
                    for (let i = 0; i < this.seats.length; i++) {
                        if (this.seats[i] && this.seats[i].playerId === msg.playerId) {
                            this.seats[i] = null;
                        }
                    }
                    this.renderRoom();
                    break;
                    
                case 'playerSat':
                    this.seats[msg.seat] = msg.seatData;
                    for (let [id, player] of this.players) {
                        if (id === msg.playerId) {
                            player.seat = msg.seat;
                            break;
                        }
                    }
                    this.renderRoom();
                    break;
                    
                case 'betPlaced':
                    if (this.seats[msg.seat]) {
                        this.seats[msg.seat].bet = msg.bet;
                        this.seats[msg.seat].points = msg.points;
                    }
                    this.renderRoom();
                    break;
                    
                case 'gameStarted':
                    this.gameState = 'playing';
                    this.currentPlayer = msg.currentPlayer;
                    this.dealerHand = msg.dealerHand;
                    this.dealerHidden = true;
                    
                    msg.seats.forEach((s, idx) => {
                        if (s && this.seats[idx]) {
                            this.seats[idx].hand = s.hand;
                        }
                    });
                    this.renderRoom();
                    break;
                    
                case 'actionTaken':
                    if (this.seats[msg.seat]) {
                        this.seats[msg.seat].hand = msg.hand;
                        this.seats[msg.seat].finished = msg.finished;
                        this.currentPlayer = msg.currentPlayer;
                    }
                    this.renderRoom();
                    break;
                    
                case 'dealerTurn':
                    this.dealerHand = msg.dealerHand;
                    this.dealerHidden = false;
                    this.gameState = 'finished';
                    
                    msg.results.forEach(r => {
                        if (this.seats[r.seat]) {
                            this.seats[r.seat].result = r.result;
                            this.seats[r.seat].points = r.points;
                        }
                    });
                    this.renderRoom();
                    break;
                    
                case 'error':
                    alert(msg.message);
                    break;
            }
        }

        renderRoomList(rooms) {
            const roomList = document.getElementById('roomList');
            
            if (!rooms || rooms.length === 0) {
                roomList.innerHTML = '<div class="room-item">📭 没有房间，点击"创建房间"</div>';
                return;
            }
            
            roomList.innerHTML = rooms.map(room => `
                <div class="room-item" onclick="showJoinModal('${room.id}')">
                    <div>
                        <strong>${room.name}</strong>
                        <div style="font-size:0.8rem;">👑 ${room.host}</div>
                    </div>
                    <div style="text-align:right;">
                        <div>👥 ${room.playerCount}/${room.maxPlayers}</div>
                    </div>
                </div>
            `).join('');
        }

        renderRoom() {
            document.getElementById('lobbyView').classList.add('hidden');
            document.getElementById('roomView').classList.remove('hidden');
            
            document.getElementById('roomNameDisplay').innerText = this.roomInfo?.name || '房间';
            document.getElementById('roomIdDisplay').innerText = '#' + (this.roomInfo?.id || '').substring(0, 6);
            
            // 玩家列表
            let playerHtml = '';
            for (let [id, player] of this.players) {
                let isMe = id === this.ws.playerId;
                playerHtml += `
                    <div class="player-card ${isMe ? 'me' : ''}">
                        <div class="host-badge">${player.isHost ? '👑' : ''}</div>
                        <div style="font-weight:bold;">${player.nickname}</div>
                        <div style="font-size:0.8rem;">💰${player.gold}</div>
                        <div style="font-size:0.7rem;">${player.seat !== null ? '座位' + (player.seat+1) : '旁观'}</div>
                    </div>
                `;
            }
            document.getElementById('playerList').innerHTML = playerHtml;
            
            let myPlayer = this.players.get(this.ws.playerId);
            document.getElementById('gameControls').classList.toggle('hidden', 
                !myPlayer?.isHost || this.gameState !== 'waiting');
            
            if (this.dealerHand && this.dealerHand.length > 0) {
                document.getElementById('dealerArea').classList.remove('hidden');
                let handHtml = '';
                if (this.dealerHidden) {
                    handHtml = this.dealerHand[0]?.suit + this.dealerHand[0]?.display + ' 🂠';
                } else {
                    handHtml = this.dealerHand.map(c => c.suit + c.display).join(' ');
                }
                document.getElementById('dealerHand').innerHTML = handHtml;
                document.getElementById('dealerPoints').innerHTML = this.dealerHidden ? '?' : this.calculateHand(this.dealerHand) + '点';
            } else {
                document.getElementById('dealerArea').classList.add('hidden');
            }
            
            let seatsHtml = '';
            for (let i = 0; i < 10; i++) {
                let seat = this.seats[i];
                let isMySeat = myPlayer?.seat === i;
                let isCurrent = this.currentPlayer === i;
                
                if (seat) {
                    seatsHtml += `
                        <div class="seat occupied ${isMySeat ? 'highlight' : ''}" style="${isCurrent ? 'border-color:#00ff00;' : ''}">
                            <div style="font-size:0.9rem; font-weight:bold;">${seat.nickname}</div>
                            <div style="font-size:0.8rem;">💰${seat.points}</div>
                            ${seat.bet > 0 ? `<div style="color:gold;">↓${seat.bet}</div>` : ''}
                            <div class="hand-cards">
                                ${seat.hand ? seat.hand.map(c => c.suit + c.display).join('') : ''}
                            </div>
                            ${seat.hand ? `<div class="points-badge">${this.calculateHand(seat.hand)}</div>` : ''}
                            ${seat.result ? `<div style="color:gold; font-size:0.8rem;">${seat.result}</div>` : ''}
                        </div>
                    `;
                } else {
                    seatsHtml += `
                        <div class="seat" onclick="sitDown(${i})">
                            <div style="font-size:2rem;">🪑</div>
                            <div style="font-size:0.7rem;">空座 ${i+1}</div>
                            <div style="font-size:0.6rem;">点击坐下</div>
                        </div>
                    `;
                }
            }
            document.getElementById('seatsContainer').innerHTML = seatsHtml;
            
            document.getElementById('bettingArea').classList.toggle('hidden', 
                !myPlayer?.seat || this.gameState !== 'waiting');
            
            document.getElementById('actionArea').classList.toggle('hidden', 
                !(this.gameState === 'playing' && this.currentPlayer === myPlayer?.seat));
        }

        renderLobby() {
            document.getElementById('lobbyView').classList.remove('hidden');
            document.getElementById('roomView').classList.add('hidden');
            this.refreshRooms();
        }

        calculateHand(hand) {
            if (!hand) return 0;
            let sum = 0;
            let aces = 0;
            for (let card of hand) {
                if (card.value === 1) {
                    aces++;
                    sum += 11;
                } else if (card.value > 10) {
                    sum += 10;
                } else {
                    sum += card.value;
                }
            }
            while (sum > 21 && aces > 0) {
                sum -= 10;
                aces--;
            }
            return sum;
        }
    }

    // ========== 全局实例 ==========
    const game = new GameManager();

    // ========== 初始化 ==========
    window.onload = function() {
        game.initPlayer();
        game.updateGoldDisplay();
        
        // 尝试加载上次使用的服务器
        const lastServer = localStorage.getItem('ws_server');
        if (lastServer) {
            document.getElementById('wsServerInput').value = lastServer;
        }
    };

    // ========== 全局函数 ==========
    window.connectToServer = () => {
        const serverUrl = document.getElementById('wsServerInput').value.trim();
        if (!serverUrl) {
            alert('请输入WebSocket服务器地址');
            return;
        }
        game.connectToServer(serverUrl);
    };

    window.showCreateRoomModal = () => {
        document.getElementById('createRoomOverlay').classList.remove('hidden');
        document.getElementById('createRoomModal').classList.remove('hidden');
    };

    window.closeCreateRoomModal = () => {
        document.getElementById('createRoomOverlay').classList.add('hidden');
        document.getElementById('createRoomModal').classList.add('hidden');
    };

    window.createRoom = () => {
        let name = document.getElementById('roomNameInput').value;
        let max = parseInt(document.getElementById('maxPlayersInput').value);
        game.createRoom(name, max);
        closeCreateRoomModal();
    };

    window.refreshRooms = () => game.refreshRooms();

    let selectedRoom = null;
    
    window.showJoinModal = (roomId) => {
        selectedRoom = { id: roomId };
        document.getElementById('joinRoomTitle').innerText = '加入房间';
        document.getElementById('joinHostName').innerText = '...';
        document.getElementById('joinPlayerCount').innerText = '?';
        document.getElementById('joinMaxPlayers').innerText = '?';
        
        document.getElementById('joinRoomOverlay').classList.remove('hidden');
        document.getElementById('joinRoomModal').classList.remove('hidden');
    };

    window.closeJoinModal = () => {
        document.getElementById('joinRoomOverlay').classList.add('hidden');
        document.getElementById('joinRoomModal').classList.add('hidden');
        selectedRoom = null;
    };

    window.joinRoom = () => {
        if (!selectedRoom) return;
        let gold = parseInt(document.getElementById('joinGoldInput').value);
        if (gold < 1000) {
            alert('金币不能少于1000');
            return;
        }
        game.joinRoom(selectedRoom.id, gold);
        closeJoinModal();
    };

    window.leaveRoom = () => game.leaveRoom();
    
    window.copyRoomInvite = () => {
        let text = `🎰 21点游戏邀请\n房间: ${game.roomInfo?.name}\n加入网址: ${window.location.href}`;
        navigator.clipboard.writeText(text);
        alert('邀请已复制');
    };
    
    window.sitDown = (i) => game.sitDown(i);
    window.startGame = () => game.startGame();
    window.placeBet = (a) => game.placeBet(a);
    window.playerAction = (a) => game.playerAction(a);
</script>
